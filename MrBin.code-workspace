    },
    "idf.eimIdfJsonPath": "C:\\Espressif\\tools\\eim_idf.json",
    "idf.saveScope": "workspace",
    "workbench.statusBar.visible": true,
    "terminal.integrated.defaultProfile.windows": "PowerShell",
    "terminal.integrated.profiles.windows": {
      "ESP-IDF PowerShell": {
        "source": "PowerShell",
        "args": [
          "-NoExit",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder:MrBin (docs/scripts)}/scripts/activate-idf.ps1"
        ],
        "icon": "circuit-board"
      }
    }
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "MrBin: Verifica workspace",
        "type": "shell",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder:MrBin (docs/scripts)}/scripts/verify-workspace.ps1"
        ],
        "group": "test",
        "presentation": {
          "reveal": "always",
          "panel": "shared"
        },
        "problemMatcher": []
      },
      {
        "label": "MrBin: Build CORE",
        "type": "shell",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-File",
          "${workspaceFolder:MrBin (docs/scripts)}/scripts/build-core.ps1"
        ],
        "group": {
          "kind": "build",
          "isDefault": true
        },
        "presentation": {
          "reveal": "always",
          "panel": "shared"
        },
        "problemMatcher": []
      },
      {
        "label": "MrBin: Clean + Build CORE",
        "type": "shell",
        "command": "powershell",
        "args": [
          "-NoProfile",
          "-ExecutionPolicy",
          "Bypass",
          "-Command",
          ". '${workspaceFolder:MrBin (docs/scripts)}/scripts/activate-idf.ps1'; Set-Location '${workspaceFolder:MrBin CORE (ESP-IDF)}'; idf.py fullclean; idf.py build"
        ],
        "group": "build",
        "presentation": {
          "reveal": "always",
          "panel": "shared"
        },
        "problemMatcher": []
      }
    ]
  },
  "extensions": {
    "recommendations": [
      "espressif.esp-idf-extension"
    ]
  }
}
