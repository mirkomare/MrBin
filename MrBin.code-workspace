    "idf.showOnboardingOnInit": false,
    "idf.espIdfPathWin": "C:\\esp\\v5.5.4\\esp-idf",
    "idf.toolsPathWin": "C:\\Espressif\\tools",
    "idf.pythonInstallPath": "C:\\Espressif\\tools\\python",
    "idf.pythonBinPathWin": "C:\\Espressif\\tools\\python\\v5.5.4\\venv\\Scripts\\python.exe",
    "idf.gitPathWin": "C:\\Program Files\\Git\\cmd\\git.exe",
    "idf.portWin": "detect",
    "idf.flashType": "UART",
    "idf.currentSetup": "C:\\esp\\v5.5.4\\esp-idf",
    "idf.customExtraVars": {
      "IDF_TARGET": "esp32p4",
      "IDF_PATH": "C:\\esp\\v5.5.4\\esp-idf",
